#
#  Petriflow Unified Backend — configuration
#  Copy this file to application.properties and add your API keys
#

#  LLM Provider
# Options: claude | openai | gemini
llm.provider=openai

#  Context mode
# Options: full - entire guide in system prompt (Claude prompt-cache, expensive but complete)
#          rag - retrieve top-K relevant chunks only (cheap, fast)
context.mode=full

#  Embedding provider (only used when context.mode=rag)
# Options: openai | gemini
embed.provider=openai

#  API keys - GET YOUR KEYS FROM:
# Anthropic (Claude): https://console.anthropic.com/settings/keys
# OpenAI: https://platform.openai.com/api-keys
# Gemini: https://aistudio.google.com/app/apikey
# GitHub: https://github.com/settings/tokens (for file upload feature)
anthropic.api-key=YOUR_ANTHROPIC_API_KEY_HERE
openai.api-key=YOUR_OPENAI_API_KEY_HERE
gemini.api-key=YOUR_GEMINI_API_KEY_HERE

#  Model overrides (optional — defaults shown)
# claude:  claude-sonnet-4-5 | claude-opus-4-5 | claude-haiku-4-5
# openai:  gpt-4o | gpt-4o-mini | gpt-4-turbo
# gemini:  gemini-2.5-flash | gemini-2.0-flash | gemini-1.5-pro
claude.model=claude-sonnet-4-5
openai.model=gpt-4o
gemini.model=gemini-2.5-flash

#  Max output tokens
claude.max-output-tokens=32000
openai.max-output-tokens=16000
gemini.max-output-tokens=65536

#  Gemini thinking (only for gemini-2.5-flash)
# 0 = disabled (faster/cheaper), -1 = auto, >0 = token budget
gemini.thinking-budget=0

#  Claude thinking
claude.thinking.enabled=false
claude.thinking.budget=1000


#  RAG tuning
rag.top-k=14
# Guide sections always included regardless of similarity score (comma-separated prefixes)
rag.always-include=7.,8.,9.

#  Server
server.port=8080
cors.allowed-origins=*
spring.mvc.async.request-timeout=600000
server.tomcat.connection-timeout=600000

#  Run log
# Each generation is appended as a JSON line to this file
run.log.path=run-log.jsonl

#  Chat history storage
chat.storage.path=chats.json

#  GitHub file upload (for "Open in Builder" feature)
# Get token from: https://github.com/settings/tokens
# Required scopes: repo (full control)
github.token=YOUR_GITHUB_TOKEN_HERE
github.username=YOUR_GITHUB_USERNAME
github.repo=YOUR_REPO_NAME
