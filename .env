# Petriflow Generator — environment config
# API keys and credentials are managed via the ⚙ Settings panel in the UI.
# They are stored in settings.json (mounted volume) and applied at runtime.

# Server
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=*
SPRING_MVC_ASYNC_REQUEST_TIMEOUT=600000
SERVER_TOMCAT_CONNECTION_TIMEOUT=600000

# Storage paths (Docker volume mounts)
CHAT_STORAGE_PATH=/app/chats.json
SETTINGS_STORAGE_PATH=/app/settings.json
RUN_LOG_PATH=/app/run-log.jsonl