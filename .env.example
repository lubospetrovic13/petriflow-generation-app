# LLM Provider
# Options: claude | openai | gemini
LLM_PROVIDER=claude

# Context mode
# Options: full - entire guide in system prompt (Claude prompt-cache, expensive but complete)
#          rag - retrieve top-K relevant chunks only (cheap, fast)
CONTEXT_MODE=full

# Embedding provider (only used when context.mode=rag)
# Options: openai | gemini
EMBED_PROVIDER=openai

# API keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Model overrides (optional – defaults shown)
# claude:  claude-sonnet-4-5 | claude-opus-4-5 | claude-haiku-4-5
# openai:  gpt-4o | gpt-4o-mini | gpt-4-turbo
# gemini:  gemini-2.5-flash | gemini-2.0-flash | gemini-1.5-pro
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4.1
GEMINI_MODEL=gemini-3-flash-preview

# Max output tokens
CLAUDE_MAX_OUTPUT_TOKENS=32000
OPENAI_MAX_OUTPUT_TOKENS=16000
GEMINI_MAX_OUTPUT_TOKENS=65536

# Claude thinking
# true = enabled, false = disabled
CLAUDE_THINKING_ENABLED=false
# Token budget for Claude thinking (only used when enabled)
CLAUDE_THINKING_BUDGET=1000

# Gemini thinking (only for gemini-2.5-flash)
# 0 = disabled (faster/cheaper), -1 = auto, >0 = token budget
GEMINI_THINKING_BUDGET=0

# RAG tuning
RAG_TOP_K=14
# Guide sections always included regardless of similarity score (comma-separated prefixes)
RAG_ALWAYS_INCLUDE=7.,8.,9.

# Server
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=*
SPRING_MVC_ASYNC_REQUEST_TIMEOUT=600000
SERVER_TOMCAT_CONNECTION_TIMEOUT=600000

# Run log
# Each generation is appended as a JSON line to this file
RUN_LOG_PATH=run-log.jsonl

# Chat history storage
CHAT_STORAGE_PATH=chats.json

# GitHub file upload (for "Open in Builder")
GITHUB_TOKEN=your-github-token-here
GITHUB_USERNAME=your-github-username
GITHUB_REPO=your-github-repo-name