# Petriflow Unified Backend - Docker Environment Configuration
# Copy this file to .env and add your API keys

# LLM Provider
# Options: claude | openai | gemini
LLM_PROVIDER=openai

# Context mode
# Options: full - entire guide in system prompt (Claude prompt-cache, expensive but complete)
#          rag - retrieve top-K relevant chunks only (cheap, fast)
CONTEXT_MODE=full

# Embedding provider (only used when CONTEXT_MODE=rag)
# Options: openai | gemini
EMBED_PROVIDER=openai

# API keys - GET YOUR KEYS FROM:
# Anthropic (Claude): https://console.anthropic.com/settings/keys
# OpenAI: https://platform.openai.com/api-keys
# Gemini: https://aistudio.google.com/app/apikey
# GitHub: https://github.com/settings/tokens (for file upload feature)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Model overrides (optional — defaults shown)
# claude:  claude-sonnet-4-5 | claude-opus-4-5 | claude-haiku-4-5
# openai:  gpt-4o | gpt-4o-mini | gpt-4-turbo
# gemini:  gemini-2.5-flash | gemini-2.0-flash | gemini-1.5-pro
CLAUDE_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-flash

# Max output tokens
CLAUDE_MAX_OUTPUT_TOKENS=32000
OPENAI_MAX_OUTPUT_TOKENS=16000
GEMINI_MAX_OUTPUT_TOKENS=65536

# Gemini thinking (only for gemini-2.5-flash)
# 0 = disabled (faster/cheaper), -1 = auto, >0 = token budget
GEMINI_THINKING_BUDGET=0

# RAG tuning
RAG_TOP_K=14
# Guide sections always included regardless of similarity score (comma-separated prefixes)
RAG_ALWAYS_INCLUDE=7.,8.,9.

# GitHub file upload (for "Open in Builder" feature)
# Get token from: https://github.com/settings/tokens
# Required scopes: repo (full control)
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE
GITHUB_USERNAME=YOUR_GITHUB_USERNAME
GITHUB_REPO=YOUR_REPO_NAME
