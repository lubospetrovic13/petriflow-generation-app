# .env.example — no longer needed for basic startup
#
# All API keys and configuration are now managed via the ⚙ Settings panel
# in the browser UI. Just run:
#
#   docker compose up
#
# Then open http://localhost:8080 and click the gear icon ⚙ to enter your keys.
#
# Optional: you can still set env vars here if you prefer (they are read as
# application.properties defaults at startup, before settings.json is applied).
#
# LLM_PROVIDER=claude
# CONTEXT_MODE=full
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...
# GEMINI_API_KEY=AIzaSy...
# GITHUB_TOKEN=ghp_...
# GITHUB_USERNAME=your-username
# GITHUB_REPO=your-repo